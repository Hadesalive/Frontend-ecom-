// House of Electronics — data model
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id             Int         @id @default(autoincrement())
  slug           String      @unique
  name           String
  price          Float
  originalPrice  Float?
  rating         Float       @default(0)
  reviews        Int         @default(0)
  image          String
  images         String      @default("[]") // JSON array of image paths
  category       String
  badge          String?
  inStock        Boolean     @default(true)
  stock          Int         @default(0)
  description    String      @default("")
  features       String      @default("[]") // JSON array of strings
  specifications String      @default("{}") // JSON object
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id         Int         @id @default(autoincrement())
  number     String      @unique
  customer   Customer    @relation(fields: [customerId], references: [id])
  customerId Int
  name       String
  email      String
  address    String?
  city       String?
  subtotal   Float
  shipping   Float
  tax        Float
  total      Float
  status     String      @default("Pending") // Pending | Paid | Fulfilled | Refunded | Cancelled
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     Int
  product     Product? @relation(fields: [productSlug], references: [slug])
  productSlug String?
  name        String
  price       Float
  quantity    Int
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Discount {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  type      String   @default("percent") // percent | fixed
  value     Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
